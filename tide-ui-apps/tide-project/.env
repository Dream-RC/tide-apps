# 项目本地运行端口号
VITE_PORT=8083

# open 运行 npm run dev 时自动打开浏览器
VITE_OPEN=false

# 打包路径
VITE_BASE_PATH=/

# 请求路径
VITE_BASE_URL='http://localhost:48080'
# ; VITE_BASE_URL='http://101.132.170.197:48080'

# 接口地址
VITE_API_URL=/admin-api

# 文件上传类型：server - 后端上传， client - 前端直连上传，仅支持S3服务
VITE_UPLOAD_TYPE=client